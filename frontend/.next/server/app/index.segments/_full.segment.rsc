19:["$","section",null,{"className":"team-section","children":["$","div",null,{"className":"container team-grid","children":[["$","div",null,{"className":"team-intro","children":[["$","h2",null,{"className":"section-title","style":{"textAlign":"left","marginBottom":"24px"},"children":"Faces Behind Jugarr"}],["$","p",null,{"children":"Jugarr started in a hostel room at 2 AM after seeing 50+ unread messages in a 'Campus Help' WhatsApp group. We realized students have incredible talent but no platform to trade it."}],["$","div",null,{"className":"editorial-line"}],["$","p",null,{"className":"signature-note","children":"Made by students, for students."}]]}],["$","div",null,{"className":"team-members","children":[["$","div",null,{"className":"member-card","children":[["$","$L10",null,{"src":{"src":"/_next/static/media/founder.17sa3e--cullh.jpeg","width":673,"height":449,"blurWidth":8,"blurHeight":5,"blurDataURL":"data:image/jpeg;base64,"},"alt":"Aryan K. Founder portrait","className":"member-image"}],["$","div",null,{"className":"member-info","children":[["$","h3",null,{"className":"member-name font-display","children":"Sagar Singh Rajawat"}],["$","p",null,{"className":"member-role font-mono","children":"Founder"}],["$","div",null,{"className":"member-socials","children":[["$","a",null,{"href":"https://www.instagram.com/sgrphicx","target":"_blank","rel":"noopener noreferrer","className":"member-social-link","aria-label":"Instagram","children":["$","svg",null,{"viewBox":"0 0 24 24","children":["$","path",null,{"d":"M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.051.014 8.333 0 8.741 0 12c