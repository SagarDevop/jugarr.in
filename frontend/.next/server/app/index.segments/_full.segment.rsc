1a:["$","section",null,{"className":"juggu-section container","children":["$","div",null,{"className":"juggu-card","children":[["$","div",null,{"className":"juggu-image-container","children":["$","$L10",null,{"src":{"src":"/_next/static/media/juggu.0ylmp5mpi2w4p.png","width":1254,"height":1254,"blurWidth":8,"blurHeight":8,"blurDataURL":"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAgAAAAICAIAAABLbSncAAAAhUlEQVR42mWOsQ3EIAxFswwdK1AyAjuwBQUFFS01FRJrsAE7UF3KQ8hGIjokOCVSfmPLz/7fx/VQ/dbW2uqPVcYYc6S1NsYAwAYd+/k5vfeMMSklAm5Qa805c84JIUqpeb0BIqaUhBCUUufcAwCEEKy1McZpWEr5h49rJq/Fadt7v7966wca3aNuGwYyDAAAAABJRU5ErkJggg=="},"alt":"Juggu - Jugarr official mascot character shape of letter J","className":"juggu-image"}]}],["$","div",null,{"className":"juggu-content","children":[["$","h2",null,{"className":"juggu-title","children":"Meet Juggu: The 'J' of Jugarr"}],["$","div",null,{"className":"editorial-line","style":{"margin":"12px auto"}}],["$","p",null,{"className":"hero-subtitle","style":{"maxWidth":"none"},"children":["Juggu is not just a character—he is the literal ",["$","strong",null,{"children":"\"J\""}]," of Jugarr. He is the ultimate street-smart broke genius representing the hustle, resourcefulness, and mutual support of Indian campus life. Whenever notes move, gear changes hands, or cash is earned, Juggu is there pulling the strings."]}],["$","div",null,{"className":"juggu-badge yellow-accent","children":"Jugarr’s Official Hustle Mascot"}]]}]]}]}]
