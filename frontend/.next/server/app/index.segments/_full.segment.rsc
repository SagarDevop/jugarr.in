2:Tad1,{"@context":"https://schema.org","@graph":[{"@type":"WebSite","@id":"https://jugarr.in/#website","url":"https://jugarr.in","name":"Jugarr","description":"India’s student-to-student campus marketplace. Buy and sell books, notes, furniture, gadgets. Find internships and earn within your college.","publisher":{"@id":"https://jugarr.in/#organization"}},{"@type":"Organization","@id":"https://jugarr.in/#organization","name":"Jugarr","url":"https://jugarr.in","logo":"https://jugarr.in/assets/logo.png","sameAs":["https://www.instagram.com/jugarr.in","https://www.linkedin.com/company/jugaaddotco/posts/?feedView=all","https://www.threads.com/@jugarr.in","https://x.com/Jugaaddotco"]},{"@type":"FAQPage","@id":"https://jugarr.in/#faq","mainEntity":[{"@type":"Question","name":"What is Jugarr?","acceptedAnswer":{"@type":"Answer","text":"Jugarr is India’s student-to-student campus marketplace where college students can buy, sell, trade, and earn within their own university community. Think of it as a trusted, campus-only marketplace built exclusively for students."}},{"@type":"Question","name":"How does Jugarr work?","acceptedAnswer":{"@type":"Answer","text":"Students sign up with their college email, browse or list items and services, and connect directly with other verified students on campus. No middlemen, no shipping — just meet up on campus and exchange."}},{"@type":"Question","name":"How can students sell old books on Jugarr?","acceptedAnswer":{"@type":"Answer","text":"Simply create a listing for your old textbooks with photos and a price. Students in your college searching for those books will find your listing and reach out directly."}},{"@type":"Question","name":"Can students buy second-hand furniture on Jugarr?","acceptedAnswer":{"@type":"Answer","text":"Yes. Graduating students frequently list desks, chairs, mattresses, and shelves at affordable prices. Buyers can inspect items on campus before purchasing."}},{"@type":"Question","name":"Is Jugarr free to use?","acceptedAnswer":{"@type":"Answer","text":"Yes, Jugarr is completely free. There are no listing fees, no commissions, and no hidden charges. Every transaction is direct and between students."}},{"@type":"Question","name":"Which colleges can join Jugarr?","acceptedAnswer":{"@type":"Answer","text":"Jugarr is currently launching across select Indian colleges. Join the waitlist with your college email, and we will notify you when your campus goes live."}},{"@type":"Question","name":"How does the Jugarr waitlist work?","acceptedAnswer":{"@type":"Answer","text":"Enter your name and college email on the waitlist form. Once enough students from your campus sign up, we activate Jugarr for your college. Early members get priority access and founding member benefits."}}]}]}0:{"P":null,"c":["",""],"q":"","i":false,"f":[[["",{"children":["__PAGE__",{}]},"$undefined","$undefined",16],[["$","$1","c",{"children":[[["$","link","0",{"rel":"stylesheet","href":"/_next/static/chunks/0rfw8wjnsr5q9.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}],["$","script","script-0",{"src":"/_next/static/chunks/08yb0vyff6txf.js","async":true,"nonce":"$undefined"}],["$","script","script-1",{"src":"/_next/static/chunks/0nz2qlxv3r.27.js","async":true,"nonce":"$undefined"}]],["$","html",null,{"lang":"en","className":"playfair_display_10db438b-module__6H_IOG__variable hanken_grotesk_47c24a78-module__ua1bhq__variable jetbrains_mono_cded63f8-module__Jb6QLa__variable epilogue_35b63177-module__L9iXfa__variable light","children":[["$","head",null,{"children":["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$2"}}]}],"$L3"]}]]}],{"children":["$L4",{},null,false,null]},null,false,null],"$L5",false]],"m":"$undefined","G":["$6",["$L7"]],"S":true,"h":null,"s":"$undefined","l":"$undefined","p":"$undefined","d":"$undefined","b":"Pnx4kaLlVUgRNyxKwYfla"}
